# Vector DB
CHROMA_DB_PATH=./data/chroma_db
COLLECTION_NAME=lab8_rag_collection


# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Chọn "openai", "gemini", "nvidia", hoặc "groq"
LLM_PROVIDER=nvidia

# NVIDIA NIM (NVIDIA Build Free Credits)
NVIDIA_API_KEY=nvapi-xxxxxx
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
LLM_MODEL=google/gemma-4-31b-it
NVIDIA_MAX_RETRIES=2
NVIDIA_CONNECT_TIMEOUT=20
NVIDIA_READ_TIMEOUT=180

# Groq (OpenAI-compatible endpoint)
GROQ_API_KEY=gsk_xxxxx
GROQ_API_BASE=https://api.groq.com/openai/v1
# Ví dụ model Groq: llama-3.1-70b-versatile, llama-3.3-70b-versatile, mixtral-8x7b-32768

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=...

# Eval config (optional)
# EVAL_LLM_PROVIDER để trống -> dùng cùng provider với LLM_PROVIDER
EVAL_LLM_PROVIDER=
EVAL_JUDGE_MAX_ATTEMPTS=2
EVAL_ANSWER_MAX_ATTEMPTS=3

# === Embedding ===
# Chọn "openai", "local", hoặc "colab" (Nhóm tự thêm)
EMBEDDING_PROVIDER=colab

# Google Colab Endpoint (Ngrok/Tunnel)
EMBEDDING_ENDPOINT=http://xxxx.ngrok-free.app/embed

# Model sentence-transformers nếu dùng local embedding
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

